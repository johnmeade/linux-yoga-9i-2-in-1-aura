@@ -169,7 +172,7 @@
 						   XE_BO_FLAG_GGTT |
 						   XE_BO_FLAG_PAGETABLE,
 						   pin_params->alignment, false);
-	else
+	else if (!XE_DEVICE_WA(xe, 22019338487_display))
 		dpt = xe_bo_create_pin_map_at_novm(xe, tile0,
 						   dpt_size,  ~0ull,
 						   ttm_bo_type_kernel,
@@ -177,6 +180,9 @@
